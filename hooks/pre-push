#!/usr/bin/env bash
# Joinery pre-push hook.
# Last-line-of-defense before code leaves the local machine.
# - Refuses direct main pushes on production tier (per [git.branching] require_branch)
# - Queries roborev for critical/high findings on commits being pushed, refuses if any
# Tier-aware: reads .workshop/config.toml.
# See docs/spec.md section 8 + section 13 for design.
#
# Review gate: roborev stores reviews in ~/.roborev/reviews.db (SQLite), NOT in
# reviews/<sha>.md files. We shell out to `roborev show <sha> --json` and parse
# JSON for unresolved critical/high findings. If roborev or jq is missing, the
# gate is skipped (graceful degradation — the framework's whole point is to fail
# safe, not block users without roborev).

set -euo pipefail

CONFIG=".workshop/config.toml"
[ ! -f "$CONFIG" ] && exit 0

PYTHON=$(command -v python3 || command -v python || echo "")
[ -z "$PYTHON" ] && { echo "pre-push: python required but not found"; exit 1; }

eval "$($PYTHON -c "
import tomllib
c = tomllib.load(open('$CONFIG', 'rb'))
print(f'TIER={c[\"meta\"][\"tier\"]}')
print(f'ENABLED={str(c[\"hooks\"][\"pre_push\"]).lower()}')
print(f'REQUIRE_BRANCH={str(c[\"git\"][\"branching\"][\"require_branch\"]).lower()}')
print(f'MAIN_BRANCH={c[\"git\"][\"branching\"][\"main_branch\"]}')
" 2>/dev/null)"

[ "${ENABLED:-true}" != "true" ] && exit 0

# Capture stdin once — git sends one line per ref being pushed, and both checks
# below need to iterate it. Using a here-string after capture lets us loop twice.
STDIN_LINES=$(cat)

ZERO_SHA="0000000000000000000000000000000000000000"

# --- Check 1: refuse direct main pushes on production tier ---
# Allow the very first bootstrap push that CREATES the main branch on the remote
# (remote_sha = all zeros). Updates to an existing remote main still get refused.
if [ "${REQUIRE_BRANCH:-true}" = "true" ]; then
    while read -r local_ref local_sha remote_ref remote_sha; do
        [ -z "$local_ref" ] && continue
        remote_sha="${remote_sha%$'\r'}"
        REMOTE_BRANCH="${remote_ref##*/}"
        CURRENT=$(git branch --show-current)
        if [ "$REMOTE_BRANCH" = "${MAIN_BRANCH:-main}" ] && [ "$CURRENT" = "$REMOTE_BRANCH" ]; then
            if [ "$remote_sha" = "$ZERO_SHA" ]; then
                continue
            fi
            echo "pre-push refused: production tier requires a feature branch for changes to '$REMOTE_BRANCH'."
            echo "See docs/spec.md section 13 (Branching strategy). Create a feature branch:"
            echo "  git checkout -b feat/<short-summary>"
            echo "  git push -u origin feat/<short-summary>"
            exit 1
        fi
    done <<< "$STDIN_LINES"
fi

# --- Check 2: roborev review gate ---
# Shell out to `roborev show <sha> --json` for each commit being pushed and
# refuse the push if any has unresolved critical/high findings.
#
# Graceful degradation: if `roborev` or `jq` isn't installed, skip silently. The
# user can `workshop setup` to install roborev. Git Bash on Windows includes jq.
if command -v roborev >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    BLOCKING_SHAS=""
    while read -r local_ref local_sha remote_ref remote_sha; do
        [ -z "$local_ref" ] && continue
        local_sha="${local_sha%$'\r'}"
        remote_sha="${remote_sha%$'\r'}"
        # Determine the range of commits being pushed. If remote_sha is zeros
        # (creating the ref), check all commits unique to this branch vs main.
        if [ "$remote_sha" = "$ZERO_SHA" ]; then
            # Use the configured main branch as the base for new branches.
            BASE_REF="origin/${MAIN_BRANCH:-main}"
            git rev-parse "$BASE_REF" >/dev/null 2>&1 || BASE_REF="${MAIN_BRANCH:-main}"
            RANGE_SPEC="${BASE_REF}..${local_sha}"
        else
            RANGE_SPEC="${remote_sha}..${local_sha}"
        fi
        SHAS=$(git rev-list "$RANGE_SPEC" 2>/dev/null || true)
        for sha in $SHAS; do
            # `roborev show <sha> --json` returns review data; we want to know
            # whether any finding has severity critical|high AND is not resolved.
            # If roborev has no review for the sha (not yet reviewed), the daemon
            # might still be processing — we treat "no review yet" as PASS to
            # avoid blocking work indefinitely. Users who want stricter behavior
            # can `roborev wait <sha>` before pushing.
            REVIEW_JSON=$(roborev show "$sha" --json 2>/dev/null || echo "")
            [ -z "$REVIEW_JSON" ] && continue
            HAS_BLOCKING=$(echo "$REVIEW_JSON" | jq -e '
                [.findings[]?
                 | select((.severity // .level) == "critical" or (.severity // .level) == "high")
                 | select((.status // "open") != "resolved" and (.status // "open") != "dismissed" and (.status // "open") != "fixed")
                ] | length > 0
            ' 2>/dev/null || echo "false")
            if [ "$HAS_BLOCKING" = "true" ]; then
                BLOCKING_SHAS="$BLOCKING_SHAS $sha"
            fi
        done
    done <<< "$STDIN_LINES"
    if [ -n "$BLOCKING_SHAS" ]; then
        echo "pre-push refused: roborev found unresolved critical/high findings."
        echo "Blocking commits:"
        for sha in $BLOCKING_SHAS; do
            echo "  $sha"
            echo "    Inspect with: roborev show $sha"
        done
        echo ""
        echo "Resolve, dismiss, or mark fixed in roborev's TUI, then retry."
        echo "  roborev tui"
        exit 1
    fi
fi

exit 0
