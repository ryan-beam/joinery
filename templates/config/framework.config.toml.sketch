# Joinery framework configuration
# Generated by `workshop init` at {{init_at}}
# Tier: sketch
# See https://github.com/ryan-beam/joinery/blob/main/docs/spec.md for full reference.
#
# Sketch tier preserves the non-negotiables (learning module, explain-back, token logging)
# but turns off most rigor gates. For throwaway experiments, learning toys, quick scripts.

[meta]
project_name = "{{project_name}}"
tier = "sketch"
init_at = "{{init_at}}"
joinery_version = "{{joinery_version}}"

[features]
plan_gate = "off"
tdd_gate = "off"
adr_required = false
type_safety = "off"
adversarial_review = "off"
security_review = "off"
explain_back = true                # NON-NEGOTIABLE: comprehension never optional
side_quest_journal = true          # NON-NEGOTIABLE: learning never optional
weekly_digest = true
ratio_logging = true
token_logging = true
commit_structure = "off"

[scope]
files_in_scope = []
deviation_policy = "ignore"        # sketches don't enforce scope discipline

[review]
use_roborev = false                # sketch: no auto-review by default
writer = "claude-sonnet-4-6"
reviewer = "claude-haiku-4-5"
deep_reviewer = "claude-opus-4-7"
min_diff_lines = 50
max_diff_lines = 2000
auto_fix_scope = "all"             # sketch: auto-fix anything; iterate fast

[dependencies]
budget_per_feature = 0             # sketch: no enforcement
audit_on_add = false
languages = ["{{language}}"]

[learning]
enabled = true
side_quest_journal = true
skills_log = true
comprehension_audits = false       # sketch: heavier weekly ritual cut for throwaways
ratio_logging = true
weekly_digest = true
audit_trigger = "manual"           # sketches don't auto-prompt audits
audit_sq_threshold = 8
ratio_target = 0.30
digest_day = "sunday"

[external_sync]
enabled = false
adapter_script = ""
endpoint = ""
secret_env = ""

[git]
require_structured_commits = false
structured_commit_threshold = 10
commit_structure_skip_authors = ["ci-bot", "github-actions[bot]", "dependabot[bot]", "automation-bot"]
init_on_sketch = true              # default: init git on sketches; override with --no-git

[git.branching]
strategy = "github-flow"
require_branch = false             # sketch: direct-to-main fine
default_merge = "squash"
allowed_branch_prefixes = ["feat", "fix", "refactor", "docs", "chore", "test", "perf"]
main_branch = "main"

[lang]
primary = "{{language}}"

[lang.python]
linter = "ruff"
formatter = "ruff"
typechecker = "mypy"
typechecker_strict = false
test_runner = "pytest"
package_file = "pyproject.toml"

[lang.typescript]
linter = "biome"
formatter = "biome"
typechecker = "tsc"
typechecker_strict = false
test_runner = "vitest"
package_file = "package.json"

[hooks]
pre_commit = true                  # lint only on sketches
pre_push = false                   # sketch: no push gating
commit_msg = false                 # sketch: no commit format check
post_merge = false

[docs]
scaffold_at_init = false           # sketch: no docs/ tree scaffolded
scaffold_operations = false
scaffold_reference = false
stale_threshold_days = 90
auto_changelog_in_digest = false

[statusline]
default = "ccstatusline"
