# Joinery framework configuration
# Generated by `workshop init` at {{init_at}}
# Tier: production
# See https://github.com/ryan-beam/joinery/blob/main/docs/spec.md for full reference.

[meta]
project_name = "{{project_name}}"
tier = "production"
init_at = "{{init_at}}"
joinery_version = "{{joinery_version}}"

[features]
plan_gate = "required"             # off | advisory | required
tdd_gate = "required"              # off | advisory | required
adr_required = true
type_safety = "strict"             # off | advisory | strict
adversarial_review = "post-commit" # off | post-commit | post-merge | pr-only | on-tag
security_review = "pr-only"        # off | manual | pr-only
explain_back = true
side_quest_journal = true
weekly_digest = true
ratio_logging = true
token_logging = true
commit_structure = "enforced"      # off | encouraged | enforced

[scope]
files_in_scope = []                # populated from plan.md per feature
deviation_policy = "surface"       # surface | block | ignore

[review]
use_roborev = true                 # adopt roborev as review engine; false uses built-in fallback
use_isolated_subagent = true       # when roborev unavailable, spawn fresh-context reviewer subagent via Task tool (audit PR #6)
writer = "claude-sonnet-4-6"
reviewer = "claude-haiku-4-5"
deep_reviewer = "claude-opus-4-7"
min_diff_lines = 50
max_diff_lines = 2000
auto_fix_scope = "off"             # production: human always in the loop

[dependencies]
budget_per_feature = 3
audit_on_add = true
languages = ["{{language}}"]

[learning]
enabled = true
side_quest_journal = true
skills_log = true
comprehension_audits = true
ratio_logging = true
weekly_digest = true
audit_trigger = "20 commits OR 14 days"
audit_sq_threshold = 8
ratio_target = 0.30
digest_day = "sunday"

[external_sync]
enabled = false
adapter_script = ""
endpoint = ""
secret_env = ""

[git]
require_structured_commits = true
structured_commit_threshold = 10
commit_structure_skip_authors = ["ci-bot", "github-actions[bot]", "dependabot[bot]", "automation-bot"]
init_on_sketch = true

[git.branching]
strategy = "github-flow"
require_branch = true              # production: refuse direct main pushes
default_merge = "squash"
allowed_branch_prefixes = ["feat", "fix", "refactor", "docs", "chore", "test", "perf"]
main_branch = "main"

[lang]
primary = "{{language}}"

[lang.python]
linter = "ruff"
formatter = "ruff"
typechecker = "mypy"
typechecker_strict = true
test_runner = "pytest"
package_file = "pyproject.toml"

[lang.typescript]
linter = "biome"
formatter = "biome"
typechecker = "tsc"
typechecker_strict = true
test_runner = "vitest"
package_file = "package.json"

[hooks]
pre_commit = true
pre_push = true
commit_msg = true
post_merge = true

[docs]
scaffold_at_init = true
scaffold_operations = true
scaffold_reference = true
stale_threshold_days = 30
auto_changelog_in_digest = true

[statusline]
default = "ccstatusline"
