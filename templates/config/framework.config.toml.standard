# Joinery framework configuration
# Generated by `workshop init` at {{init_at}}
# Tier: standard
# See https://github.com/ryan-beam/joinery/blob/main/docs/spec.md for full reference.

[meta]
project_name = "{{project_name}}"
tier = "standard"
init_at = "{{init_at}}"
joinery_version = "{{joinery_version}}"

[features]
plan_gate = "advisory"             # standard: prompt but don't block
tdd_gate = "advisory"
adr_required = false               # standard: ADRs encouraged but not required
type_safety = "advisory"
adversarial_review = "pr-only"     # standard: review on PR only, not every commit
security_review = "manual"
explain_back = true
side_quest_journal = true
weekly_digest = true
ratio_logging = true
token_logging = true
commit_structure = "encouraged"

[scope]
files_in_scope = []
deviation_policy = "surface"

[review]
use_roborev = true
writer = "claude-sonnet-4-6"
reviewer = "claude-haiku-4-5"
deep_reviewer = "claude-opus-4-7"
min_diff_lines = 50
max_diff_lines = 2000
auto_fix_scope = "style"           # standard: auto-fix style/format only

[dependencies]
budget_per_feature = 5             # standard: more relaxed than production
audit_on_add = true
languages = ["{{language}}"]

[learning]
enabled = true
side_quest_journal = true
skills_log = true
comprehension_audits = true
ratio_logging = true
weekly_digest = true
audit_trigger = "20 commits OR 14 days"
audit_sq_threshold = 8
ratio_target = 0.30
digest_day = "sunday"

[external_sync]
enabled = false
adapter_script = ""
endpoint = ""
secret_env = ""

[git]
require_structured_commits = false # standard: encouraged but not enforced
structured_commit_threshold = 10
commit_structure_skip_authors = ["ci-bot", "github-actions[bot]", "dependabot[bot]", "automation-bot"]
init_on_sketch = true

[git.branching]
strategy = "github-flow"
require_branch = true              # standard: default yes, override allowed for trivial fixes
default_merge = "squash"
allowed_branch_prefixes = ["feat", "fix", "refactor", "docs", "chore", "test", "perf"]
main_branch = "main"

[lang]
primary = "{{language}}"

[lang.python]
linter = "ruff"
formatter = "ruff"
typechecker = "mypy"
typechecker_strict = false         # standard: mypy default, not --strict
test_runner = "pytest"
package_file = "pyproject.toml"

[lang.typescript]
linter = "biome"
formatter = "biome"
typechecker = "tsc"
typechecker_strict = true
test_runner = "vitest"
package_file = "package.json"

[hooks]
pre_commit = true
pre_push = true
commit_msg = true                  # standard: still validates if structured commits used
post_merge = true

[docs]
scaffold_at_init = true
scaffold_operations = false        # standard: lighter docs scaffold
scaffold_reference = false
stale_threshold_days = 60          # standard: more relaxed staleness threshold
auto_changelog_in_digest = true

[statusline]
default = "ccstatusline"
